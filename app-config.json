{
  "app_config": {
    "name": "FountainHome",
    "display_name": "Fountain Stream",
    "version": "1.0.0",
    "version_code": 1,
    "package_name": "com.fountainstream.app",
    "description": "Your ultimate streaming destination with a cyber fountain experience",
    "icon": {
      "path": "public/fountain-icon.jpg",
      "sizes": [192, 512]
    },
    "splash": {
      "background_color": "#000000",
      "text_color": "#FFFFFF",
      "logo": "public/fountain-icon.jpg"
    }
  },
  "build": {
    "framework": "capacitor",
    "platforms": ["android", "ios", "web"],
    "android": {
      "min_sdk_version": 24,
      "target_sdk_version": 35,
      "compile_sdk_version": 35,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE"
      ],
      "gradle_properties": {
        "org.gradle.jvmargs": "-Xmx1024m",
        "android.enableJetifier": "true"
      }
    }
  },
  "features": {
    "offline_mode": true,
    "push_notifications": false,
    "background_sync": true,
    "cache_strategy": "network-first",
    "storage": {
      "local_storage": true,
      "indexed_db": true,
      "cache_api": true
    }
  },
  "performance": {
    "minify": true,
    "source_maps": false,
    "lazy_load": true,
    "code_split": true
  },
  "security": {
    "https_only": true,
    "csp_enabled": true,
    "x_frame_options": "DENY",
    "x_content_type_options": "nosniff",
    "allow_external_domains": [
      "api.themoviedb.org",
      "image.tmdb.org",
      "*.vidsrc.me",
      "*.vidplay.online",
      "*.vidsrc.pro"
    ]
  },
  "deployment": {
    "play_store": {
      "enabled": true,
      "package_name": "com.fountainstream.app",
      "track": "internal"
    },
    "direct": {
      "enabled": true,
      "storage": "s3",
      "bucket": "fountain-releases"
    }
  }
}
