<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FountainHome" parent="Theme.AppCompat.NoActionBar">
        <item name="android:colorBackground">@color/dark_background</item>
        <item name="android:colorForeground">@color/white</item>
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorPrimaryDark">@color/dark_background</item>
        <item name="colorAccent">@color/accent_cyan</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@color/dark_background</item>
        <item name="android:navigationBarColor">@color/dark_background</item>
        <item name="android:fitsSystemWindows">true</item>
    </style>
</resources>
